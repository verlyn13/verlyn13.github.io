{
  "ink": { "$type": "color", "$value": "{palette.ink.900}" },
  "paper": { "$type": "color", "$value": "{palette.paper.97}" },
  "muted": { "$type": "color", "$value": "{palette.ink.muted}" },
  "accent": { "$type": "color", "$value": "{palette.blue.base}" },
  "accent-light": { "$type": "color", "$value": "{palette.blue.light}" },
  "accent-subtle": { "$type": "color", "$value": "{palette.blue.subtle}" },
  "accent-dark": { "$type": "color", "$value": "{palette.blue.strong}" },
  "accent-2": { "$type": "color", "$value": "{palette.green.base}" },
  "warn": { "$type": "color", "$value": "{palette.orange.base}" },
  "ok": { "$type": "color", "$value": "{palette.green.base}" },

  "heading": { "$type": "color", "$value": "{palette.ink.800}", "$description": "h3 ink" },
  "heading-2": { "$type": "color", "$value": "{palette.ink.750}", "$description": "h4 ink" },

  "surface": {
    "$type": "color",
    "$value": "hsl(0 0% 100% / 0.75)",
    "$description": "raised card surface"
  },
  "surface-pill": {
    "$type": "color",
    "$value": "hsl(0 0% 100% / 0.65)",
    "$description": "outline pill surface"
  },
  "surface-hover": {
    "$type": "color",
    "$value": "hsl(0 0% 100% / 0.9)",
    "$description": "pill/card hover surface"
  },
  "on-accent": {
    "$type": "color",
    "$value": "{palette.white}",
    "$description": "text/icon on an accent fill"
  },
  "ink-print": {
    "$type": "color",
    "$value": "{palette.black}",
    "$description": "pure black for @media print"
  },

  "inset-warm": {
    "$type": "color",
    "$value": "{palette.paper.96}",
    "$description": "warm inset/section background"
  },
  "inset-cool": {
    "$type": "color",
    "$value": "{palette.slate.bg}",
    "$description": "cool neutral chip background"
  },
  "code-bg": { "$type": "color", "$value": "{palette.slate.code}" },
  "paper-deep": {
    "$type": "color",
    "$value": "{palette.paper.95}",
    "$description": "body-gradient end"
  },
  "paper-deeper": { "$type": "color", "$value": "{palette.paper.94}" },

  "ring": {
    "$type": "color",
    "$value": "hsl(220 70% 44% / 0.35)",
    "$description": "focus ring + accent border"
  },
  "accent-tint": {
    "$type": "color",
    "$value": "hsl(220 70% 44% / 0.06)",
    "$description": "callout tint"
  },
  "rule-highlight": {
    "$type": "color",
    "$value": "hsl(220 70% 44% / 0.15)",
    "$description": "rule-of-thumb highlight"
  },

  "border-faint": { "$type": "color", "$value": "hsl(220 18% 18% / 0.06)" },
  "border-soft": { "$type": "color", "$value": "hsl(220 18% 18% / 0.08)" },
  "border-hairline": { "$type": "color", "$value": "hsl(220 18% 18% / 0.1)" },

  "ok-bg": { "$type": "color", "$value": "{palette.green.bg}" },
  "ok-tint": { "$type": "color", "$value": "hsl(155 50% 33% / 0.08)" },
  "green-bg": { "$type": "color", "$value": "{palette.green.bg}" },
  "amber-bg": { "$type": "color", "$value": "{palette.paper.amber}" },
  "amber-ink": { "$type": "color", "$value": "{palette.orange.dark}" },
  "ok-ink": {
    "$type": "color",
    "$value": "{palette.green.ink}",
    "$description": "live-pill text on --ok-bg (merged green ramp; AA verified by check:contrast)"
  },
  "accent-ink": {
    "$type": "color",
    "$value": "{palette.blue.ink}",
    "$description": "development-pill text on --accent-light (AA verified by check:contrast)"
  },
  "green-ink": {
    "$type": "color",
    "$value": "{palette.green.ink}",
    "$description": "production-pill text on --green-bg (AA verified by check:contrast)"
  },
  "warn-tint": { "$type": "color", "$value": "hsl(22 90% 52% / 0.1)" },

  "border": { "$value": "1px solid {palette.ink.line}" },
  "shadow": { "$value": "0 10px 30px hsl(220 25% 15% / 0.1)" },
  "shadow-hard": { "$value": "0 1px 0 hsl(220 25% 15% / 0.15)" },
  "shadow-lift": {
    "$value": "0 15px 40px hsl(220 25% 15% / 0.15)",
    "$description": "card/approach hover lift"
  },
  "shadow-soft": {
    "$value": "0 4px 12px hsl(220 25% 15% / 0.08)",
    "$description": "mobile-nav dropdown"
  },
  "shadow-float": {
    "$value": "0 4px 12px hsl(220 25% 15% / 0.1)",
    "$description": "back-to-top button"
  },

  "font": {
    "$value": "ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif"
  },
  "mono": {
    "$value": "ui-monospace, SFMono-Regular, Menlo, Consolas, \"Liberation Mono\", monospace"
  },
  "lh": { "$value": "1.55", "$description": "body default line-height (alias of --lh-base)" },

  "text-3xs": {
    "$value": "0.75rem",
    "$description": "uppercase eyebrow labels; flagship/status/badge tags; smallest mono facets"
  },
  "text-2xs": {
    "$value": "0.8125rem",
    "$description": "meta rows, captions, mono stack/source/axis, small pill labels"
  },
  "text-xs": {
    "$value": "0.9375rem",
    "$description": "secondary body, card thesis/description, list items, section intro, location"
  },
  "text-sm": { "$value": "1rem", "$description": "base body" },
  "text-md": {
    "$value": "1.0625rem",
    "$description": "lead/supporting paragraphs, hero bio/pitch, colophon lead, h4"
  },
  "text-lg": { "$value": "1.1875rem", "$description": "h3, subtitles, evidence-card value" },
  "text-h2": {
    "$value": "clamp(1.35rem, 1.3vw + 1rem, 1.85rem)",
    "$description": "section-divider headings"
  },
  "text-h1": {
    "$value": "clamp(1.8rem, 2.2vw + 1rem, 2.6rem)",
    "$description": "page titles"
  },
  "text-display": {
    "$value": "clamp(2.35rem, 4.5vw + 1rem, 3.5rem)",
    "$description": "the home positioning claim only (type-as-signature)"
  },

  "lh-display": { "$value": "1.05", "$description": "display claim + large clamped headings" },
  "lh-heading": { "$value": "1.15", "$description": "h1-h4" },
  "lh-snug": { "$value": "1.4", "$description": "compact UI, badges, stat captions" },
  "lh-base": { "$value": "1.55", "$description": "body default" },
  "lh-relaxed": { "$value": "1.6", "$description": "long prose" },

  "fw-normal": { "$value": "400" },
  "fw-medium": { "$value": "500" },
  "fw-semibold": { "$value": "600" },
  "fw-strong": {
    "$value": "650",
    "$description": "house 'warm-but-not-squishy' emphasis weight"
  },

  "tracking-tight": { "$value": "-0.02em", "$description": "display + headings" },
  "tracking-normal": { "$value": "0.01em", "$description": "body" },
  "tracking-label": { "$value": "0.05em", "$description": "uppercase eyebrows" },

  "radius": { "$value": "{scale.radius.md}" },
  "radius-sm": { "$value": "{scale.radius.sm}" },
  "space-1": { "$value": "{scale.space.1}" },
  "space-2": { "$value": "{scale.space.2}" },
  "space-3": { "$value": "{scale.space.3}" },
  "space-4": { "$value": "{scale.space.4}" },
  "space-5": { "$value": "{scale.space.5}" },
  "space-6": { "$value": "{scale.space.6}" },
  "section-gap": {
    "$value": "clamp(2.5rem, 6vw, 4rem)",
    "$description": "standard major-section rhythm (global; was experience-page-only)"
  },
  "measure": { "$value": "72ch" },
  "measure-wide": { "$value": "1080px" }
}
